<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC "-//Google Inc.//DTD Google Web Toolkit 2.12.1//EN" "http://gwtproject.org/doctype/2.12.1/gwt-module.dtd">
<module rename-to="mindustrydemo">

    <!-- Inherit the core GWT modules -->
    <inherits name="com.google.gwt.user.User"/>
    <inherits name="com.google.gwt.user.theme.clean.Clean"/>
    
    <!-- Inherit libGDX/Arc GWT backend -->
    <inherits name="arc.backends.gwt.GwtBackend"/>
    
    <!-- Specify the entry point class -->
    <entry-point class="mindustry.html.MinimalDemo"/>
    
    <!-- Source paths - ONLY the html module, NOT core -->
    <source path=""/>
    
    <!-- Public resources -->
    <public path="web"/>
    
    <!-- Configure compiler options -->
    <set-configuration-property name="gwt.enableClosureCompiler" value="true"/>
    <set-configuration-property name="gwt.closureCompilerFlags" value="--compilation_level=SIMPLE_OPTIMIZATIONS --warning_level=QUIET"/>
    
    <!-- Single permutation for faster compilation -->
    <collapse-all-properties/>
    
    <!-- WebGL 2 configuration -->
    <set-property name="gdx.gles2" value="true"/>
    <set-property name="gdx.gles3" value="false"/>
    
    <!-- Disable features not supported in HTML5 -->
    <set-property name="gdx.disableAudio" value="false"/>
    <set-property name="gdx.disableCursor" value="false"/>
    
    <!-- Memory/settings -->
    <set-property name="gwt.maxPermutationCount" value="1"/>
    
</module>